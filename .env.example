# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=challenge_votacao
POSTGRES_PASSWORD=challenge_votacao
POSTGRES_DB=challenge_votacao
DATABASE_URL=postgresql+asyncpg://challenge_votacao:challenge_votacao@postgres/challenge_votacao

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gerar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=insecure-dev-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin padrão (seed) ───────────────────────────────────────────────────────
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin

# ── Criptografia de campos sensíveis ─────────────────────────────────────────
# Gerar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── E-mail (Mailpit em dev) ───────────────────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1026
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@challenge_votacao.com.br

# ── Storage S3 / MinIO ────────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9020
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=challenge_votacao
S3_REGION=us-east-1

# ── Trial padrão (dias) ───────────────────────────────────────────────────────
DEFAULT_TRIAL_DAYS=30
